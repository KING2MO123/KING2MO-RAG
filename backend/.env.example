# ============================================================
# KING2MO — Exemple de configuration
# Copiez ce fichier en « .env » (dans backend/, ou à côté de l'exe) et
# renseignez vos valeurs. Ne committez JAMAIS votre vrai .env (il est ignoré).
# ============================================================

# --- Accès à l'API locale -----------------------------------
# Laissez vide : un token fort est généré automatiquement au 1er lancement.
BACKEND_API_TOKEN=""

# --- Fournisseur LLM ----------------------------------------
# gemini | deepseek | gemini-openai | ollama | custom
LLM_PROVIDER="gemini"
GEMINI_API_KEY=""
# Nom du modèle (tous fournisseurs). Défaut : gemini-2.5-flash
LLM_MODEL=""
# Pour les fournisseurs custom / ollama uniquement :
LLM_BASE_URL=""

# --- Recherche web (optionnelle) ----------------------------
TAVILY_API_KEY=""

# --- Embeddings ---------------------------------------------
# Défaut : modèle multilingue (FR + EN). Changer impose de vider chroma_db/.
EMBED_MODEL=""

# --- Recherche / CRAG ---------------------------------------
# Seuil de pertinence [0-1] déclenchant le repli web quand les documents
# locaux sont trop faibles. 0 = désactivé (web seulement si aucun document).
RELEVANCE_THRESHOLD="0"

# --- Limites & garde-fous -----------------------------------
MAX_UPLOAD_MB="25"
MAX_DECOMPRESSED_MB="200"
MAX_CONCURRENT_CHATS="3"
MAX_CHATS_PER_MINUTE="30"
# Plafond de dépense estimée par jour en USD (0 = illimité).
DAILY_SPEND_CAP_USD="0"

# --- CORS (mode développement seulement) --------------------
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:3050,http://127.0.0.1:3050"

# --- Débogage -----------------------------------------------
# 1 = active les DevTools de la fenêtre native.
KING2MO_DEBUG="0"
